{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|mjs)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=31536000, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|svg|webp|avif|ico|woff|woff2|ttf|otf|eot)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, s-maxage=31536000, stale-while-revalidate=2592000"
        }
      ]
    },
    {
      "source": "/(.*)\\.json$",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(robots.txt|sitemap.xml)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/roadmap/algorithms",
      "destination": "/roadmap/dsa/algorithms",
      "permanent": true
    },
    {
      "source": "/roadmap/complexity-analysis",
      "destination": "/roadmap/dsa/complexity-analysis",
      "permanent": true
    },
    {
      "source": "/roadmap/data-structures",
      "destination": "/roadmap/dsa/data-structures",
      "permanent": true
    },
    {
      "source": "/roadmap/searching",
      "destination": "/roadmap/dsa/searching",
      "permanent": true
    },
    {
      "source": "/roadmap/sorting",
      "destination": "/roadmap/dsa/sorting",
      "permanent": true
    },
    {
      "source": "/roadmap/trees-heaps",
      "destination": "/roadmap/dsa/trees-heaps",
      "permanent": true
    },
    {
      "source": "/roadmap/graph-algorithms",
      "destination": "/roadmap/dsa/graph-algorithms",
      "permanent": true
    },
    {
      "source": "/roadmap/dynamic-programming",
      "destination": "/roadmap/dsa/dynamic-programming",
      "permanent": true
    },
    {
      "source": "/roadmap/greedy-algorithms",
      "destination": "/roadmap/dsa/greedy-algorithms",
      "permanent": true
    },
    {
      "source": "/roadmap/advanced-techniques",
      "destination": "/roadmap/dsa/advanced-techniques",
      "permanent": true
    },
    {
      "source": "/",
      "destination": "/projects/maj",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "maj.sagecode.org"
        }
      ]
    }
  ]
}