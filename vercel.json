{
    "buildCommand":  "npm run build",
    "outputDirectory":  "public",
    "cleanUrls":  false,
    "trailingSlash":  false,
    "headers":  [
                    {
                        "source":  "/(.*)",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "public, max-age=0, s-maxage=600, stale-while-revalidate=86400"
                                        }
                                    ]
                    },
                    {
                        "source":  "/(.*)\\.(css|js|mjs)$",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "public, max-age=86400, s-maxage=31536000, stale-while-revalidate=604800"
                                        }
                                    ]
                    },
                    {
                        "source":  "/(.*)\\.(png|jpg|jpeg|gif|svg|webp|avif|ico|woff|woff2|ttf|otf|eot)$",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "public, max-age=604800, s-maxage=31536000, stale-while-revalidate=2592000"
                                        }
                                    ]
                    },
                    {
                        "source":  "/(.*)\\.json$",
                        "headers":  [
                                        {
                                            "key":  "Content-Type",
                                            "value":  "application/json"
                                        },
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400"
                                        }
                                    ]
                    },
                    {
                        "source":  "/(robots.txt|sitemap.xml)",
                        "headers":  [
                                        {
                                            "key":  "Cache-Control",
                                            "value":  "public, max-age=300, s-maxage=3600, stale-while-revalidate=86400"
                                        }
                                    ]
                    }
                ],
    "redirects":  [
                      {
                          "source":  "/roadmap/:track(cse|csp|dsa|dba|dsl|tek|sml|hpc|osd)",
                          "destination":  "/roadmap/:track/",
                          "permanent":  true
                      },
                      {
                          "source":  "/roadmap/:track(cse|dsa|dba|dsl|tek|sml|hpc|osd)/:topic",
                          "destination":  "/roadmap/:track/:topic.html",
                          "permanent":  true
                      },
                      {
                          "source":  "/",
                          "destination":  "/projects/maj",
                          "permanent":  true,
                          "has":  [
                                      {
                                          "type":  "host",
                                          "value":  "maj.sagecode.org"
                                      }
                                  ]
                      }
                  ]
}
