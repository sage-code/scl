{
  "name": "sage-code-scl",
  "version": "1.0.0",
  "private": true,
  "description": "Sage-Code static website migration workspace (Vercel + Supabase backend).",
  "scripts": {
    "build": "node build.js",
    "clean:only": "node scripts/clean-build.js",
    "clean": "node scripts/clean-build.js",
    "clean:rebuild": "node scripts/clean-build.js --rebuild",
    "migrate:plan": "python scripts/python/migrate_to_static_structure.py --mode copy",
    "migrate:apply": "python scripts/python/migrate_to_static_structure.py --mode copy --apply",
    "migrate:move": "python scripts/python/migrate_to_static_structure.py --mode move --apply",
    "migrate:report": "python scripts/python/migration_status_report.py",
    "migrate:prepare": "powershell -ExecutionPolicy Bypass -File scripts/powershell/prepare-migration.ps1",
    "test:local": "powershell -ExecutionPolicy Bypass -File scripts/powershell/test-local.ps1",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/powershell/dev.ps1"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.6",
    "@vercel/speed-insights": "^1.0.10"
  }
}
